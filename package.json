{
  "name": "ember-website",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "description": "Source Code for the Ember website https://emberjs.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ember-learn/ember-website.git"
  },
  "license": "MIT",
  "author": "",
  "scripts": {
    "build": "node scripts/generate-content.mjs && vite build",
    "lint": "concurrently \"pnpm:lint:*(!fix)\" --names \"lint:\"",
    "lint:css": "stylelint \"**/*.css\"",
    "lint:css:fix": "concurrently \"pnpm:lint:css -- --fix\"",
    "lint:fix": "concurrently \"pnpm:lint:*:fix\" --names \"fix:\"",
    "lint:hbs": "ember-template-lint .",
    "lint:hbs:fix": "ember-template-lint . --fix",
    "lint:js": "eslint . --cache",
    "lint:js:fix": "eslint . --fix",
    "start": "node scripts/generate-content.mjs && vite",
    "test": "concurrently \"pnpm:lint\" \"pnpm:test:*\" --names \"lint,test:\"",
    "test:ember": "vite build --mode development && testem ci"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/eslint-parser": "^7.25.1",
    "@babel/plugin-transform-runtime": "^7.29.0",
    "@ember/string": "^4.0.1",
    "@ember/test-helpers": "^5.4.1",
    "@embroider/core": "^4.4.3",
    "@embroider/macros": "^1.20.2",
    "@embroider/router": "^3.0.6",
    "@embroider/vite": "^1.5.2",
    "@glimmer/component": "^2.0.0",
    "@glimmer/tracking": "^1.1.2",
    "@nullvoxpopuli/ember-composable-helpers": "^5.3.1",
    "@rollup/plugin-babel": "^7.0.0",
    "algoliasearch": "^3.33.0",
    "babel-plugin-ember-template-compilation": "^3.1.0",
    "blurhash": "^2.0.5",
    "concurrently": "^8.2.2",
    "dayjs": "^1.10.7",
    "decorator-transforms": "^2.3.1",
    "deepmerge": "^4.0.0",
    "ember-a11y-testing": "^8.0.0",
    "ember-data": "~5.8.1",
    "ember-inflector": "^6.0.0",
    "ember-load-initializers": "^3.0.1",
    "ember-modifier": "^4.2.0",
    "ember-page-title": "^8.2.3",
    "ember-primitives": "^0.55.0",
    "ember-qunit": "^9.0.4",
    "ember-resolver": "^13.1.1",
    "ember-source": "~5.12.0",
    "ember-strict-application-resolver": "^0.1.1",
    "ember-template-lint": "^6.0.0",
    "ember-truth-helpers": "^3.0.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-ember": "^12.2.1",
    "eslint-plugin-n": "^16.6.2",
    "eslint-plugin-prettier": "^5.2.1",
    "eslint-plugin-qunit": "^8.1.2",
    "highcharts": "^10.1.0",
    "normalize.css": "^8.0.1",
    "prettier": "^3.3.3",
    "qunit": "^2.22.0",
    "qunit-dom": "^3.2.1",
    "stylelint": "^15.11.0",
    "stylelint-config-standard": "^34.0.0",
    "stylelint-prettier": "^4.1.0",
    "testem": "^3.15.2",
    "tracked-built-ins": "^3.3.0",
    "vite": "^8.0.3"
  },
  "engines": {
    "node": ">= 20"
  },
  "pnpm": {
    "overrides": {
      "sharp": "^0.33.5"
    },
    "onlyBuiltDependencies": [
      "esbuild",
      "fsevents",
      "sharp"
    ]
  },
  "packageManager": "pnpm@10.4.1+sha512.c753b6c3ad7afa13af388fa6d808035a008e30ea9993f58c6663e2bc5ff21679aa834db094987129aa4d488b86df57f7b634981b2f827cdcacc698cc0cfb88af",
  "exports": {
    "./tests/*": "./tests/*",
    "./*": "./app/*"
  }
}
